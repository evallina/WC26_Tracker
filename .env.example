# Copy this file to `.env` and fill in your key. `.env` is gitignored — never commit it.
#
# football-data.org free-tier token (used by tools/fetch-live.mjs and the GitHub Action).
# Get one at https://www.football-data.org/client/register
FOOTBALLDATA_KEY=your_football-data.org_token_here

# Optional: an api-sports.io key instead (the fetcher auto-selects by which key is set).
# APIFOOTBALL_KEY=your_api-sports.io_token_here
